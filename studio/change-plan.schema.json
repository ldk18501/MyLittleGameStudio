{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/change-plan.schema.json",
  "title": "MLGS Unity architecture change plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "projectKind", "intensity", "targetModuleId", "architectureDecision", "decisionReason", "legacyTradeoff", "responsibilities", "reuseExisting", "newAbstractions", "plannedFiles", "dependencyChanges", "lifecycle", "dataOwnership", "errorHandling", "testPlan", "architectVerdict", "status", "blockers", "updated"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "taskId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "projectKind": { "enum": ["new-project", "small-existing", "large-framework"] },
    "intensity": { "enum": ["lightweight", "standard", "deep"] },
    "targetModuleId": { "type": "string" },
    "architectureDecision": { "enum": ["extend-existing", "adapt-existing", "replace-legacy", "create-new-foundation", "isolated-new-module"] },
    "decisionReason": { "type": "string", "minLength": 1 },
    "legacyTradeoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consistencyBenefit", "newRequirementBenefit", "risk", "approvalRequired", "approved"],
      "properties": {
        "consistencyBenefit": { "type": "string" },
        "newRequirementBenefit": { "type": "string" },
        "risk": { "type": "string" },
        "approvalRequired": { "type": "boolean" },
        "approved": { "type": "boolean" }
      }
    },
    "responsibilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scriptRole", "path", "moduleId", "owns"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "scriptRole": { "enum": ["pure-csharp", "monobehaviour", "scriptableobject", "editor", "test", "generated"] },
          "path": { "type": "string", "minLength": 1 },
          "moduleId": { "type": "string" },
          "owns": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "reuseExisting": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "newAbstractions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "reason"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["manager", "service", "module", "interface", "factory", "event", "configuration", "repository", "none"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "plannedFiles": { "$ref": "#/$defs/plannedFiles" },
    "dependencyChanges": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "lifecycle": { "type": "string", "minLength": 1 },
    "dataOwnership": { "type": "string", "minLength": 1 },
    "errorHandling": { "type": "string", "minLength": 1 },
    "testPlan": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "architectVerdict": { "enum": ["pending", "pass", "fail", "blocked"] },
    "status": { "enum": ["draft", "approved", "implemented", "blocked"] },
    "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "updated": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "plannedFiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modify", "create", "delete", "evidence"],
      "properties": {
        "modify": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "create": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "delete": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
