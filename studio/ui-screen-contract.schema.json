{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/ui-screen-contract.schema.json",
  "title": "MLGS UI screen inventory and contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "updated", "screens"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.1" },
    "profileId": { "type": "string" },
    "updated": { "type": "string", "minLength": 1 },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scopeId", "purpose", "visualTargetIds", "prefabOrDocument", "states", "controls", "componentAudit", "artAssetIds", "audioIds", "status", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "scopeId": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "visualTargetIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "prefabOrDocument": { "type": "string" },
          "states": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "controls": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "componentAudit": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "method", "referenceImage", "referenceResolution", "completenessNotes", "artDirectorVerdict", "components"],
            "properties": {
              "status": { "enum": ["pending", "decomposed", "approved"] },
              "method": { "enum": ["manual-visual-audit", "assisted-visual-audit"] },
              "referenceImage": { "type": "string" },
              "referenceResolution": { "$ref": "#/$defs/size" },
              "completenessNotes": { "type": "string" },
              "artDirectorVerdict": { "enum": ["pending", "pass", "fail"] },
              "components": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "role", "controlIds", "productionDecision", "assetId", "referenceRect", "requiredStates", "reuseKey", "notes"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "role": { "type": "string", "minLength": 1 },
                    "controlIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
                    "productionDecision": { "enum": ["generated-asset", "reuse-existing", "procedural-unity", "typography-only"] },
                    "assetId": { "type": "string" },
                    "referenceRect": { "$ref": "#/$defs/rect" },
                    "requiredStates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
                    "reuseKey": { "type": "string", "minLength": 1 },
                    "notes": { "type": "string" }
                  }
                }
              }
            }
          },
          "artAssetIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "audioIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "status": { "enum": ["planned", "specified", "implemented", "integrated", "approved"] },
          "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    }
  },
  "$defs": {
    "size": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "rect": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 4,
      "maxItems": 4
    }
  }
}
