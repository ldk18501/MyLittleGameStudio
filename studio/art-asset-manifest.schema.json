{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/art-asset-manifest.schema.json",
  "title": "MLGS 正式美术资源清单",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updated", "visualTargetPath", "assets"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.6" },
    "updated": { "type": "string" },
    "visualTargetPath": { "type": "string", "minLength": 1 },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "usage", "requiredFor", "visualTargets", "sourceType", "source", "license", "promptMetadata", "visualComponent", "sourceFile", "outputPath", "status", "statusHistory", "placeholder", "importRecipe", "usageMetadata", "integrity", "references", "evidence", "reviewPath"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "usage": { "type": "string", "minLength": 1 },
          "requiredFor": { "enum": ["vertical-slice", "content-complete", "alpha", "beta", "release-candidate", "release"] },
          "visualTargets": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "sourceType": { "enum": ["generated", "original", "licensed", "commissioned", "derived"] },
          "source": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "promptMetadata": { "type": "string" },
          "visualComponent": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "role", "reuseKey", "generationUnit", "styleDescription", "promptCore", "textPolicy", "requiredStates", "sourceComponents", "preserve", "avoid"],
            "properties": {
              "mode": { "enum": ["standalone", "screen-derived"] },
              "role": { "type": "string", "minLength": 1 },
              "reuseKey": { "type": "string", "minLength": 1 },
              "generationUnit": { "enum": ["single-sprite", "nine-slice", "icon", "state-set", "procedural-unity"] },
              "styleDescription": { "type": "string", "minLength": 1 },
              "promptCore": { "type": "string", "minLength": 1 },
              "textPolicy": { "enum": ["no-text", "separate-runtime-text", "baked-approved-text"] },
              "requiredStates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "sourceComponents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["screenId", "componentId", "visualTargetId", "referenceImage", "referenceResolution", "rect"],
                  "properties": {
                    "screenId": { "type": "string", "minLength": 1 },
                    "componentId": { "type": "string", "minLength": 1 },
                    "visualTargetId": { "type": "string", "minLength": 1 },
                    "referenceImage": { "type": "string", "minLength": 1 },
                    "referenceResolution": { "$ref": "#/$defs/size" },
                    "rect": { "$ref": "#/$defs/rect" }
                  }
                }
              },
              "preserve": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "avoid": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
            },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "screen-derived" } }, "required": ["mode"] },
                "then": { "properties": { "sourceComponents": { "minItems": 1 } } }
              }
            ]
          },
          "sourceFile": { "type": "string", "minLength": 1 },
          "outputPath": { "type": "string", "minLength": 1 },
          "status": { "enum": ["planned", "prompt-ready", "generated", "selected", "processed", "imported", "referenced", "approved"] },
          "statusHistory": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "at", "evidence", "note"],
              "properties": {
                "status": { "enum": ["planned", "prompt-ready", "generated", "selected", "processed", "imported", "referenced", "approved"] },
                "at": { "type": "string", "minLength": 1 },
                "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
                "note": { "type": "string" }
              }
            }
          },
          "placeholder": { "type": "boolean" },
          "importRecipe": { "type": "string", "minLength": 1 },
          "usageMetadata": { "type": "string", "minLength": 1 },
          "integrity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceLayout", "extractionMode", "minimumTransparentMargin", "minimumFrameMargin", "expectedFrames", "maxSignificantComponents", "maxBaselineVariance", "maxFrameSizeVarianceRatio", "reportPath", "verdict"],
            "properties": {
              "sourceLayout": { "enum": ["individual", "registered-sheet", "unverified-sheet", "procedural"] },
              "extractionMode": { "enum": ["single-object", "object-aware", "explicit-rectangles", "fixed-grid", "procedural"] },
              "minimumTransparentMargin": { "type": "integer", "minimum": 0 },
              "minimumFrameMargin": { "type": "integer", "minimum": 0 },
              "expectedFrames": { "type": "integer", "minimum": 1 },
              "maxSignificantComponents": { "type": "integer", "minimum": 1 },
              "maxBaselineVariance": { "type": "integer", "minimum": 0 },
              "maxFrameSizeVarianceRatio": { "type": "number", "minimum": 0, "maximum": 1 },
              "reportPath": { "type": "string" },
              "verdict": { "enum": ["pending", "pass", "fail", "unavailable", "error"] }
            }
          },
          "references": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "reviewPath": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "size": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "rect": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 4,
      "maxItems": 4
    }
  }
}
