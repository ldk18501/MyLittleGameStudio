{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/visual-target.schema.json",
  "title": "MLGS approved visual targets",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updated", "targets"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.1" },
    "updated": { "type": "string", "minLength": 1 },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "usage", "imagePath", "source", "approved", "nonNegotiables", "forbidden", "targetResolution", "styleLock"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "usage": { "type": "string", "minLength": 1 },
          "imagePath": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "approved": { "type": "boolean" },
          "nonNegotiables": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "forbidden": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "targetResolution": { "type": "string", "minLength": 1 },
          "styleLock": { "$ref": "#/$defs/styleLock" }
        }
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "styleLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["renderingMedium", "palette", "colorTemperature", "saturation", "contrast", "lighting", "materials", "surfaceTexture", "shapeLanguage", "uiTreatment", "preserve", "avoid"],
      "properties": {
        "renderingMedium": { "type": "string", "minLength": 1 },
        "palette": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hex", "role"],
            "properties": {
              "hex": { "$ref": "#/$defs/hexColor" },
              "role": { "type": "string", "minLength": 1 }
            }
          }
        },
        "colorTemperature": { "type": "string", "minLength": 1 },
        "saturation": { "type": "string", "minLength": 1 },
        "contrast": { "type": "string", "minLength": 1 },
        "lighting": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "materials": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "surfaceTexture": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "shapeLanguage": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "uiTreatment": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "preserve": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "avoid": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
