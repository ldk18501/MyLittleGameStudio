{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MyLittleGameStudio project write lease",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "invocationId", "taskId", "projectId", "projectRoot", "readOnly", "paths", "acquiredAt", "expiresAt"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "invocationId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string" },
    "projectId": { "type": "string", "minLength": 1 },
    "projectRoot": { "type": "string", "minLength": 1 },
    "readOnly": { "type": "boolean" },
    "paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "acquiredAt": { "type": "string", "minLength": 1 },
    "expiresAt": { "type": "string", "minLength": 1 }
  }
}
