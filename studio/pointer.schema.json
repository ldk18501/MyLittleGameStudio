{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MyLittleGameStudio current project pointer",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updated", "statePath", "projectRoot"],
  "properties": {
    "schemaVersion": { "enum": ["1.0", "1.1"] },
    "updated": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "statePath": { "type": "string", "minLength": 1 },
    "projectRoot": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "schemaVersion": { "const": "1.1" } } },
      "then": { "required": ["projectId"] }
    }
  ]
}
