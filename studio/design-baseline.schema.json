{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/design-baseline.schema.json",
  "title": "MLGS frozen design baseline",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "status", "frozenAt", "sources"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "frozen", "stale"] },
    "frozenAt": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "affectsScopeIds", "affectsAssetIds", "affectsWorkPackageIds", "invalidatesStages"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
          "affectsScopeIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "affectsAssetIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "affectsWorkPackageIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "invalidatesStages": { "type": "array", "items": { "enum": ["vertical-slice", "content-complete", "alpha", "beta", "release-candidate", "release"] }, "uniqueItems": true }
        }
      }
    }
  }
}
