{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/execution-strategy.schema.json",
  "title": "MLGS risk-based execution strategy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "workPackageId", "strategy", "reason", "groups", "synthesisOwner", "maxParallel", "maxRounds", "stopCondition", "updated"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "workPackageId": { "type": "string", "minLength": 1 },
    "strategy": { "enum": ["direct", "pipeline", "fan-out-and-synthesize", "adversarial-review", "loop-until-done"] },
    "domain": { "enum": ["gameplay", "art", "ui", "architecture", "qa", "production"] },
    "reason": { "type": "string", "minLength": 1 },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "objective", "inputs", "outputs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "inputs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "outputs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "synthesisOwner": { "type": "string", "minLength": 1 },
    "maxParallel": { "type": "integer", "minimum": 1, "maximum": 4 },
    "maxRounds": { "type": "integer", "minimum": 1, "maximum": 5 },
    "stopCondition": { "type": "string", "minLength": 1 },
    "updated": { "type": "string", "minLength": 1 }
  }
}
