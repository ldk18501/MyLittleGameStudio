{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/work-package.schema.json",
  "title": "MLGS bounded work package",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "title", "objective", "scopeIds", "nonGoals", "owner", "support", "dependencies", "strategy", "executionPlanPath", "verificationPolicy", "status", "successCriteria", "budget", "attempts", "declaredVerdict", "objectiveVerdict", "gaps", "blockers", "updated"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "workKind": { "enum": ["general", "code", "art", "design", "qa", "content", "release"] },
    "contextPackPath": { "type": "string" },
    "changePlanPath": { "type": "string" },
    "conformanceReportPath": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "scopeIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "nonGoals": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "owner": { "type": "string", "minLength": 1 },
    "support": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "strategy": { "enum": ["direct", "pipeline", "fan-out-and-synthesize", "adversarial-review", "loop-until-done"] },
    "executionPlanPath": { "type": "string" },
    "verificationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cadence", "aggregateSmallChanges", "focusedChecks", "routineFullSuiteMaxRunsPerAttempt", "rerunPassingChecks", "fullRegressionTriggers"],
      "properties": {
        "cadence": { "enum": ["task-boundary", "risk-triggered", "continuous"] },
        "aggregateSmallChanges": { "type": "boolean" },
        "focusedChecks": { "enum": ["acceptance-only", "risk-triggered", "every-subchange"] },
        "routineFullSuiteMaxRunsPerAttempt": { "type": "integer", "minimum": 1, "maximum": 3 },
        "rerunPassingChecks": { "enum": ["on-relevant-input-change", "always", "never"] },
        "fullRegressionTriggers": {
          "type": "array",
          "items": {
            "enum": [
              "shared-contract-change",
              "scene-or-prefab-wiring",
              "persistence-or-config-change",
              "previous-check-failure",
              "build-or-phase-gate",
              "owner-request"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "status": { "enum": ["ready", "in-progress", "review", "done", "blocked", "failed"] },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "evidence", "objectiveVerdict", "objectiveChecks"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "objectiveVerdict": { "enum": ["pending", "pass", "fail", "unknown"] },
          "objectiveChecks": { "$ref": "#/$defs/objectiveChecks" }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "currentAttempt"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 5 },
        "currentAttempt": { "type": "integer", "minimum": 0, "maximum": 5 }
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "status", "started", "finished", "artifacts", "evidence", "gaps"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "status": { "enum": ["in-progress", "pass", "fail", "blocked"] },
          "started": { "type": "string" },
          "finished": { "type": "string" },
          "artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "gaps": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "declaredVerdict": { "enum": ["pending", "pass", "fail", "blocked"] },
    "objectiveVerdict": { "enum": ["pending", "pass", "fail", "blocked", "unknown"] },
    "gaps": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "updated": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "objectiveChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "contains", "command", "status", "detail"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["file-exists", "file-contains", "command"] },
          "path": { "type": "string" },
          "contains": { "type": "string" },
          "command": { "type": "string" },
          "status": { "enum": ["pending", "pass", "fail", "skipped"] },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
