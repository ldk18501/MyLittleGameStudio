{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/art-import-recipe.schema.json",
  "title": "MLGS Unity art import recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assetId", "texturePath", "textureType", "spriteMode", "pixelsPerUnit", "pivot", "border", "meshType", "alphaIsTransparency", "mipmaps", "filterMode", "wrapMode", "maxSize", "compression", "sourceLayout", "extractionMode", "integrityGate", "slicing", "atlas", "addressable", "platformOverrides", "unityImporterEvidence", "nineSliceEvidence"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "assetId": { "type": "string", "minLength": 1 },
    "texturePath": { "type": "string", "minLength": 1 },
    "textureType": { "enum": ["Sprite", "Default", "NormalMap", "GUI"] },
    "spriteMode": { "enum": ["Single", "Multiple", "Polygon"] },
    "pixelsPerUnit": { "type": "number", "exclusiveMinimum": 0 },
    "pivot": { "$ref": "#/$defs/vector2Normalized" },
    "border": { "$ref": "#/$defs/vector4NonNegative" },
    "meshType": { "enum": ["Tight", "FullRect"] },
    "alphaIsTransparency": { "type": "boolean" },
    "mipmaps": { "type": "boolean" },
    "filterMode": { "enum": ["Point", "Bilinear", "Trilinear"] },
    "wrapMode": { "enum": ["Clamp", "Repeat", "Mirror", "MirrorOnce"] },
    "maxSize": { "enum": [32, 64, 128, 256, 512, 1024, 2048, 4096, 8192, 16384] },
    "compression": { "enum": ["Uncompressed", "Compressed", "CompressedHQ", "CompressedLQ"] },
    "sourceLayout": { "enum": ["individual", "registered-sheet", "unverified-sheet", "procedural"] },
    "extractionMode": { "enum": ["single-object", "object-aware", "explicit-rectangles", "fixed-grid", "procedural"] },
    "integrityGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumTransparentMargin", "minimumFrameMargin", "expectedFrames", "maxSignificantComponents", "maxBaselineVariance", "maxFrameSizeVarianceRatio", "requireNoEdgeContact", "requireIndependentFrameValidation"],
      "properties": {
        "minimumTransparentMargin": { "type": "integer", "minimum": 0 },
        "minimumFrameMargin": { "type": "integer", "minimum": 0 },
        "expectedFrames": { "type": "integer", "minimum": 1 },
        "maxSignificantComponents": { "type": "integer", "minimum": 1 },
        "maxBaselineVariance": { "type": "integer", "minimum": 0 },
        "maxFrameSizeVarianceRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "requireNoEdgeContact": { "type": "boolean" },
        "requireIndependentFrameValidation": { "type": "boolean" }
      }
    },
    "slicing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "cellSize", "offset", "padding", "rects"],
      "properties": {
        "mode": { "enum": ["none", "fixed-grid", "explicit-rectangles", "sliced"] },
        "cellSize": { "$ref": "#/$defs/vector2NonNegative" },
        "offset": { "$ref": "#/$defs/vector2NonNegative" },
        "padding": { "$ref": "#/$defs/vector2NonNegative" },
        "rects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "x", "y", "width", "height"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "x": { "type": "integer", "minimum": 0 },
              "y": { "type": "integer", "minimum": 0 },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "atlas": { "type": "string" },
    "addressable": { "type": "boolean" },
    "platformOverrides": { "type": "array", "items": { "type": "object" } },
    "unityImporterEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "nineSliceEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  },
  "$defs": {
    "vector2Normalized": {
      "type": "array", "prefixItems": [{ "type": "number", "minimum": 0, "maximum": 1 }, { "type": "number", "minimum": 0, "maximum": 1 }], "minItems": 2, "maxItems": 2
    },
    "vector2NonNegative": {
      "type": "array", "prefixItems": [{ "type": "integer", "minimum": 0 }, { "type": "integer", "minimum": 0 }], "minItems": 2, "maxItems": 2
    },
    "vector4NonNegative": {
      "type": "array", "prefixItems": [{ "type": "number", "minimum": 0 }, { "type": "number", "minimum": 0 }, { "type": "number", "minimum": 0 }, { "type": "number", "minimum": 0 }], "minItems": 4, "maxItems": 4
    }
  }
}
