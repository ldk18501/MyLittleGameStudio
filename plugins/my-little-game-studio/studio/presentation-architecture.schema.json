{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlegamestudio.local/schemas/presentation-architecture.schema.json",
  "title": "MLGS Unity presentation architecture contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "dimension", "pureUIGame", "ownerApprovedPureUI", "coreGameplayRenderer", "uiRenderer", "coreGameplayPaths", "uiPaths", "allowedUGUIExceptions", "requiredWorldComponents", "evidence", "architectVerdict", "status", "blockers", "updated"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0" },
    "dimension": { "enum": ["2d", "2.5d", "3d"] },
    "pureUIGame": { "type": "boolean" },
    "ownerApprovedPureUI": { "type": "boolean" },
    "coreGameplayRenderer": { "enum": ["sprite-scene", "tilemap-scene", "3d-scene", "hybrid-scene", "ugui"] },
    "uiRenderer": { "enum": ["ugui", "uitoolkit", "hybrid"] },
    "coreGameplayPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "uiPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "allowedUGUIExceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "ownerApproved"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "ownerApproved": { "type": "boolean" }
        }
      }
    },
    "requiredWorldComponents": { "type": "array", "items": { "enum": ["SpriteRenderer", "TilemapRenderer", "Animator", "ParticleSystem", "MeshRenderer"] }, "uniqueItems": true },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "architectVerdict": { "enum": ["pending", "pass", "fail", "blocked"] },
    "status": { "enum": ["draft", "approved", "blocked"] },
    "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "updated": { "type": "string", "minLength": 1 }
  }
}
